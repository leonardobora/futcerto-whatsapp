# =============================================================================
# FutCerto v2.0 - Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# -----------------------------------------------------------------------------
# AI Model (OpenAI)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
AI_MODEL=gpt-4-turbo
AI_TEMPERATURE=0.5

# -----------------------------------------------------------------------------
# Mapbox (Geolocalização)
# -----------------------------------------------------------------------------
MAPBOX_API_KEY=

# -----------------------------------------------------------------------------
# Evolution API (se estiver usando para WhatsApp)
# Docker local: http://localhost:8080
# -----------------------------------------------------------------------------
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE_NAME=futcerto

# -----------------------------------------------------------------------------
# Tyxter Studio (se estiver usando para produção)
# -----------------------------------------------------------------------------
TYXTER_API_KEY=
TYXTER_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Configuração da Aplicação
# -----------------------------------------------------------------------------
APP_PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Regras de Negócio
# -----------------------------------------------------------------------------
MAX_BOOKING_DAYS_AHEAD=30
CACELAMENTO_HORAS_MINIMO=2
COMISSAO_PERCENTUAL=10
